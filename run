#!/usr/bin/bash

build=""

if [ -f /usr/bin/ninja ]; then
     build="-G Ninja"
fi

# cmake -B build $build -DCMAKE_BUILD_TYPE=Release || exit
cmake -B build $build -DCMAKE_BUILD_TYPE=Debug || exit
cmake --build build || exit

build/src/main exit

cd visu

if [ ! -d ./venv ]; then
     python3 -m venv venv
     venv/bin/pip install manim matplotlib
fi

venv/bin/manim -qm -p anim.py || exit